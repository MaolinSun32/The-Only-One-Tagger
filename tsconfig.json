{
	"compilerOptions": {
		"baseUrl": "src",
		"strict": true,
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ES6",
		"allowJs": true,
		"moduleResolution": "node",
		"importHelpers": true,
		"noUncheckedIndexedAccess": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"lib": [
			"DOM",
			"ES2018"
		]
	},
	"include": [
		"src/**/*.ts"
	]
}
